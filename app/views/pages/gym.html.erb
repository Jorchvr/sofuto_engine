<div class="min-h-screen bg-[#080808] text-gray-200 font-sans p-6 overflow-hidden">
  
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-red-600/5 blur-[120px]"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-red-900/10 blur-[100px]"></div>
  </div>

  <div class="max-w-[1800px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6 relative z-10">
    
    <div class="lg:col-span-8 flex flex-col gap-6">
      
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-4xl font-black tracking-tighter text-white">Gym <span class="text-red-600">Control</span></h1>
          <div class="flex items-center gap-3 mt-2">
            <p class="text-xs font-medium text-gray-400 uppercase tracking-widest">Usuario: <span class="text-white">Admin</span></p>
            <button class="bg-red-600/10 hover:bg-red-600/20 text-red-500 border border-red-600/30 px-3 py-1 rounded-lg text-[10px] font-bold uppercase transition-all">
              Cerrar Sesión
            </button>
          </div>
        </div>
        <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center shadow-2xl">
           <img src="https://via.placeholder.com/40x40/red/white?text=LOGO" class="rounded-lg opacity-80" alt="Logo Gym">
        </div>
      </div>

      <div class="bg-white/5 backdrop-blur-md border border-white/10 p-2 rounded-2xl flex gap-2">
        <input type="text" placeholder="Buscar # Cliente o nombre" 
               class="flex-1 bg-transparent border-none px-6 py-3 text-sm focus:outline-none placeholder:text-gray-600">
        <button class="bg-red-600 hover:bg-red-500 text-white px-8 py-3 rounded-xl text-xs font-black uppercase tracking-widest transition-all shadow-lg shadow-red-900/20">
          Buscar
        </button>
      </div>

      <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-[2rem] p-8 relative overflow-hidden group">
        <div class="flex justify-between items-start">
          <div class="space-y-1">
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-[0.2em]">Ventas de Hoy</h3>
            <p class="text-6xl font-black text-white tracking-tighter">$2905.0</p>
            <p class="text-xs text-red-500/80 font-mono">33 operaciones realizadas</p>
          </div>
          <div class="flex gap-2">
            <button class="bg-white/5 hover:bg-red-600/20 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-bold uppercase transition-all">Ajustes / venta negativa</button>
            <button class="bg-white/5 hover:bg-white/10 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-bold uppercase transition-all">Historial (por día)</button>
          </div>
        </div>
        
        <div class="mt-8 flex gap-2">
          <button class="bg-white/5 hover:bg-white/10 border border-white/10 px-6 py-2 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all">Corte del día</button>
          <button class="bg-white/5 hover:bg-white/10 border border-white/10 px-6 py-2 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all">Descargar Excel del día</button>
        </div>
      </div>

      <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-[2rem] p-8">
        <h3 class="text-xs font-bold text-gray-500 uppercase tracking-[0.2em] mb-2">Personas que han entrado (hoy)</h3>
        <p class="text-7xl font-black text-white tracking-tighter">6</p>
        <p class="text-[10px] text-gray-600 uppercase tracking-widest mt-2">Registro diario de ingresos</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <button class="bg-white/5 hover:bg-white/10 border border-white/10 py-5 rounded-2xl font-bold text-[11px] uppercase tracking-widest transition-all">Clientes</button>
        <button class="bg-white/5 hover:bg-white/10 border border-white/10 py-5 rounded-2xl font-bold text-[11px] uppercase tracking-widest transition-all">Registrar Cliente</button>
        <button class="bg-red-600/20 hover:bg-red-600 text-red-500 hover:text-white border border-red-600/30 py-5 rounded-2xl font-black text-[11px] uppercase tracking-widest transition-all">Cobrar mensualidad</button>
        <button class="bg-red-600/20 hover:bg-red-600 text-red-500 hover:text-white border border-red-600/30 py-5 rounded-2xl font-black text-[11px] uppercase tracking-widest transition-all">Clases (Griselle)</button>
      </div>
    </div>

    <div class="lg:col-span-4">
      <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-[2rem] h-full flex flex-col overflow-hidden">
        
        <div class="p-6 border-b border-white/5">
          <h2 class="text-2xl font-black tracking-tight text-white uppercase">Tienda <span class="text-red-600">Online</span></h2>
        </div>

        <div class="p-6 flex-1 flex flex-col gap-6 overflow-y-auto custom-scrollbar">
          
          <div>
            <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.3em] mb-4">Productos rápidos</h3>
            <div class="grid grid-cols-1 gap-3">
              <button class="bg-white/5 border border-white/5 p-4 rounded-2xl flex justify-between items-center group hover:bg-red-600/10 hover:border-red-600/30 transition-all text-left">
                <div class="space-y-1">
                  <p class="text-xs font-bold uppercase text-gray-300 group-hover:text-white transition-colors">Agua kirland</p>
                  <p class="text-lg font-black text-red-500">$15.0</p>
                </div>
                <div class="text-right">
                  <p class="text-[9px] text-gray-600 uppercase">Stock: 181</p>
                </div>
              </button>

              <button class="bg-white/5 border border-white/5 p-4 rounded-2xl flex justify-between items-center group hover:bg-red-600/10 hover:border-red-600/30 transition-all text-left">
                <div class="space-y-1">
                  <p class="text-xs font-bold uppercase text-gray-300 group-hover:text-white transition-colors">Quemador</p>
                  <p class="text-lg font-black text-red-500">$20.0</p>
                </div>
                <div class="text-right">
                  <p class="text-[9px] text-gray-600 uppercase">Stock: 98</p>
                </div>
              </button>
            </div>
          </div>

          <div class="mt-auto pt-6 border-t border-white/5 space-y-6">
            <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-[0.3em]">Carrito</h3>
            <div class="flex flex-col items-center justify-center py-8 opacity-20">
              <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
              <p class="text-xs uppercase tracking-widest">No hay productos en el carrito</p>
            </div>

            <div class="space-y-4">
              <div class="flex flex-col gap-2">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Método de pago:</p>
                <div class="flex gap-4">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="pay" checked class="accent-red-600">
                    <span class="text-xs">Efectivo</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer opacity-40">
                    <input type="radio" name="pay" class="accent-red-600">
                    <span class="text-xs">Transferencia</span>
                  </label>
                </div>
              </div>
              
              <div class="flex justify-between items-end border-t border-white/5 pt-4">
                <p class="text-xs font-bold text-gray-500 uppercase">Total:</p>
                <p class="text-4xl font-black text-white">$0.0</p>
              </div>

              <button class="w-full bg-red-600 hover:bg-red-500 py-5 rounded-2xl text-sm font-black uppercase tracking-[0.3em] transition-all shadow-xl shadow-red-900/40">
                Cobrar ahora
              </button>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>

  <style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 10px; }
  </style>
</div>