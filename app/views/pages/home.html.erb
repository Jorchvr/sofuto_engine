  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pt-10 flex flex-wrap items-center justify-center gap-10 md:gap-16">
    
    <a href="<%= bienes_raices_path %>" class="text-gray-300 hover:text-white font-serif tracking-[0.2em] text-xs md:text-sm uppercase transition-all hover:scale-105">
      Bienes Raíces
    </a>
    
    <a href="<%= gym_path %>" class="text-amber-500 hover:text-amber-400 font-serif tracking-[0.2em] text-xs md:text-sm uppercase transition-all hover:scale-105 border-b border-amber-500 pb-1">
      Gym
    </a>
    
    <a href="<%= barber_path %>" class="text-gray-300 hover:text-white font-serif tracking-[0.2em] text-xs md:text-sm uppercase transition-all hover:scale-105">
      Barber
    </a>
    
    <a href="<%= architecture_path %>" class="text-gray-300 hover:text-white font-serif tracking-[0.2em] text-xs md:text-sm uppercase transition-all hover:scale-105">
      Architecture
    </a>

  </div>

</div>

<script>
  // Control del Scroll
  document.addEventListener('scroll', function() {
    const creativo = document.getElementById('diseno-creativo');
    const lienzo = document.getElementById('lienzo-creativo');
    if (creativo && !creativo.classList.contains('hidden') && lienzo) {
      if (window.scrollY > 50) {
        lienzo.classList.add('en-fila');
      } else {
        lienzo.classList.remove('en-fila');
      }
    }
  });

  // Control de la Mini Ventana (Modal)
  function abrirModal(e) {
    e.preventDefault(); // Evita el salto de página
    const modal = document.getElementById('modal-who');
    const content = document.getElementById('modal-content');
    modal.classList.remove('hidden');
    setTimeout(() => {
      modal.classList.remove('opacity-0');
      modal.classList.add('opacity-100');
      content.classList.remove('scale-95');
      content.classList.add('scale-100');
    }, 10);
  }

  function cerrarModal() {
    const modal = document.getElementById('modal-who');
    const content = document.getElementById('modal-content');
    modal.classList.remove('opacity-100');
    modal.classList.add('opacity-0');
    content.classList.remove('scale-100');
    content.classList.add('scale-95');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 300);
  }
</script>