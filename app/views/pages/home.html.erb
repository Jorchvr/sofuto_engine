<div id="diseno-creativo" class="transition-all duration-700 w-full">
  
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@500;700&display=swap');
    .fuente-manuscrita { font-family: 'Caveat', cursive; }

    .item-creativo {
      position: absolute;
      transition: all 0.9s cubic-bezier(0.4, 0, 0.2, 1);
    }

    #frase-1 { top: 15%; left: 25%; transform: translate(-50%, -50%) rotate(-6deg); }
    #frase-2 { top: 40%; left: 75%; transform: translate(-50%, -50%) rotate(3deg); }
    #frase-3 { top: 80%; left: 30%; transform: translate(-50%, -50%) rotate(-4deg); }

    #btn-1 { top: 25%; left: 55%; transform: translate(-50%, -50%); }
    #btn-2 { top: 55%; left: 20%; transform: translate(-50%, -50%); }
    #btn-3 { top: 65%; left: 85%; transform: translate(-50%, -50%); }
    #btn-4 { top: 85%; left: 65%; transform: translate(-50%, -50%); }

    #indicador-scroll { top: 8%; right: 5%; opacity: 1; transform: translateY(0); }
    #nota-who { top: 60%; left: 50%; opacity: 0; transform: translate(-50%, -50%) scale(0.2) rotate(20deg); pointer-events: none; }

    .en-fila #frase-1 { top: 25%; left: 20%; transform: translate(-50%, -50%) rotate(0deg); width: 25%; text-align: center; }
    .en-fila #frase-2 { top: 25%; left: 50%; transform: translate(-50%, -50%) rotate(0deg); width: 30%; text-align: center; }
    .en-fila #frase-3 { top: 25%; left: 80%; transform: translate(-50%, -50%) rotate(0deg); width: 25%; text-align: center; }
    .en-fila .texto-frase { font-size: 2.2rem !important; }

    .en-fila #btn-1 { top: 75%; left: 25%; transform: translate(-50%, -50%) scale(0.8); }
    .en-fila #btn-2 { top: 75%; left: 45%; transform: translate(-50%, -50%) scale(0.8); }
    .en-fila #btn-3 { top: 75%; left: 65%; transform: translate(-50%, -50%) scale(0.8); }
    .en-fila #btn-4 { top: 75%; left: 85%; transform: translate(-50%, -50%) scale(0.8); }

    .en-fila #indicador-scroll { opacity: 0; transform: translateY(-30px); pointer-events: none; }
    .en-fila #nota-who { 
      top: 50%; 
      left: 10%; 
      opacity: 1; 
      transform: translate(-50%, -50%) scale(1) rotate(-8deg); 
      pointer-events: auto; 
    }
  </style>

  <div class="w-full h-[150vh]">
    <div id="lienzo-creativo" class="sticky top-16 w-full h-[calc(100vh-4rem)] bg-[#F5F0E6] overflow-hidden border-b border-gray-200">
      
      <div id="indicador-scroll" class="item-creativo z-30 animate-bounce">
        <p class="fuente-manuscrita text-4xl text-rose-500 font-bold tracking-wider">Scroll!! ↓</p>
      </div>

      <a href="#" onclick="abrirModal(event)" id="nota-who" class="item-creativo z-40 w-44 h-44 bg-[#fef08a] shadow-xl flex items-center justify-center hover:scale-110 transition-transform duration-200">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-16 h-6 bg-white/40 backdrop-blur-sm shadow-sm rotate-3"></div>
        <p class="fuente-manuscrita text-4xl text-gray-800">Who we are?</p>
      </a>

      <div id="frase-1" class="item-creativo w-max z-10 pointer-events-none">
        <p class="texto-frase fuente-manuscrita text-5xl md:text-6xl text-gray-800 opacity-80 tracking-wide transition-all duration-700">If u dream, we can create.</p>
      </div>
      <div id="frase-2" class="item-creativo w-max z-10 pointer-events-none">
        <p class="texto-frase fuente-manuscrita text-4xl md:text-5xl text-indigo-900 opacity-90 transition-all duration-700">Creative Software Creative Solutions.</p>
      </div>
      <div id="frase-3" class="item-creativo w-max z-10 pointer-events-none">
        <p class="texto-frase fuente-manuscrita text-5xl md:text-6xl text-rose-800 opacity-75 transition-all duration-700">The normal things are bored.</p>
      </div>

      <div id="btn-1" class="item-creativo z-20">
        <a href="<%= bienes_raices_path %>" class="block hover:scale-110 transition-transform duration-300 group drop-shadow-2xl">
          <svg class="w-56 h-56 text-indigo-500 group-hover:text-indigo-600 transition-colors" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M45.7,-76.3C58.9,-69.3,69.1,-55.3,77.5,-40.8C85.9,-26.3,92.5,-11.3,91.8,3.4C91.1,18.1,83.1,32.5,73.1,44.7C63.1,56.9,51.1,66.9,37.3,73.6C23.5,80.3,7.9,83.7,-7.1,81.8C-22.1,79.9,-36.6,72.7,-49.2,63.1C-61.8,53.5,-72.5,41.5,-79.8,27.5C-87.1,13.5,-91,-2.5,-87.8,-17.6C-84.6,-32.7,-74.3,-46.9,-61.6,-54.6C-48.9,-62.3,-33.8,-63.5,-20.1,-67.2C-6.4,-70.9,5.9,-77.1,20.2,-79.5C34.5,-81.9,50.8,-80.5,45.7,-76.3Z" transform="translate(100 100)" />
          </svg>
          <span class="absolute inset-0 flex items-center justify-center text-white font-bold text-2xl tracking-wider -rotate-6">Bienes Raices</span>
        </a>
      </div>

      <div id="btn-2" class="item-creativo z-20">
        <a href="<%= gym_path %>" class="block hover:scale-110 transition-transform duration-300 group drop-shadow-2xl">
          <svg class="w-64 h-64 text-rose-500 group-hover:text-rose-600 transition-colors" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M51.8,-68.5C65.5,-58.5,73.9,-41.4,79.1,-23.7C84.3,-6,86.3,12.3,79.6,28.2C72.9,44.1,57.5,57.6,40.4,66.4C23.3,75.2,4.5,79.3,-13.3,76.5C-31.1,73.7,-47.9,64,-61.4,50.3C-74.9,36.6,-85.1,18.9,-85.5,1C-85.9,-16.9,-76.5,-34.5,-63.4,-47.8C-50.3,-61.1,-33.5,-70.1,-16.4,-73.4C0.7,-76.7,17.8,-74.3,38.1,-78.5Z" transform="translate(100 100)" />
          </svg>
          <span class="absolute inset-0 flex items-center justify-center text-white font-bold text-3xl tracking-wider rotate-3">Gym</span>
        </a>
      </div>

      <div id="btn-3" class="item-creativo z-20">
        <a href="<%= barber_path %>" class="block hover:scale-110 transition-transform duration-300 group drop-shadow-2xl">
          <svg class="w-52 h-52 text-amber-500 group-hover:text-amber-600 transition-colors" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M38.1,-63.9C49.9,-54.2,60.4,-43.3,67.6,-30.3C74.8,-17.3,78.7,-2.2,76.8,12.5C74.9,27.2,67.2,41.5,55.9,51.8C44.6,62.1,29.7,68.4,14.2,72.1C-1.3,75.8,-17.4,76.9,-31.6,71.5C-45.8,66.1,-58.1,54.2,-66.2,40.1C-74.3,26,-78.2,9.7,-75.4,-5.2C-72.6,-20.1,-63.1,-33.6,-51.6,-43.9C-40.1,-54.2,-26.6,-61.3,-12.6,-65.4C1.4,-69.5,15.4,-70.6,26.3,-73.6Z" transform="translate(100 100)" />
          </svg>
          <span class="absolute inset-0 flex items-center justify-center text-white font-bold text-2xl tracking-wider -rotate-12">Barber</span>
        </a>
      </div>

      <div id="btn-4" class="item-creativo z-20">
        <a href="<%= architecture_path %>" class="block hover:scale-110 transition-transform duration-300 group drop-shadow-2xl">
          <svg class="w-60 h-60 text-teal-500 group-hover:text-teal-600 transition-colors" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M42.7,-73.3C55.9,-66.2,67.6,-54.6,74.6,-40.7C81.6,-26.8,83.9,-10.6,82.4,5.1C80.9,20.8,75.6,36.1,65.8,48.2C56,60.3,41.7,69.2,26.2,74.5C10.7,79.8,-6,81.5,-21.5,78.1C-37,74.7,-51.3,66.2,-61.7,54.1C-72.1,42,-78.6,26.3,-80.7,10.2C-82.8,-5.9,-80.5,-22.4,-72.6,-36.1C-64.7,-49.8,-51.2,-60.7,-36.8,-67.2C-22.4,-73.7,-7.1,-75.8,7.3,-78.4Z" transform="translate(100 100)" />
          </svg>
          <span class="absolute inset-0 flex items-center justify-center text-white font-bold text-2xl tracking-wider rotate-6">Architecture</span>
        </a>
      </div>

    </div>
  </div>

  <div id="modal-who" class="fixed inset-0 z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-gray-900/40 backdrop-blur-sm" onclick="cerrarModal()"></div>
    <div class="relative bg-white p-10 rounded-3xl shadow-2xl max-w-md w-full text-center border-4 border-[#fef08a] transform scale-95 transition-transform duration-300" id="modal-content">
      <button onclick="cerrarModal()" class="absolute top-4 right-4 text-gray-400 hover:text-rose-500 transition-colors">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      <h2 class="fuente-manuscrita text-5xl text-gray-800 mb-6 font-bold">Who we are?</h2>
      <p class="text-xl text-gray-600 font-medium leading-relaxed italic">
        "Just 2 young guys trying to make your dreams come true through crazy solutions."
      </p>
    </div>
  </div>

</div>



