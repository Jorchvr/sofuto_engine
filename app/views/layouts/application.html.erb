<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sofuto Engine" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Activa Tailwind y los scripts limpios %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@500;700&display=swap');
      .fuente-manuscrita-global { font-family: 'Caveat', cursive; }
      
      @keyframes balanceo {
        0%, 100% { transform: rotate(-8deg); }
        50% { transform: rotate(8deg); }
      }
      .logo-colgando {
        transform-origin: top center;
        animation: balanceo 4s ease-in-out infinite;
      }
    </style>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen relative">
    
    <header class="bg-white/90 backdrop-blur-md shadow-sm sticky top-0 z-50 h-16 transition-all duration-500">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full">
        <div class="flex items-center justify-between h-full">
          
          <div class="flex items-center">
            
            <div id="header-creativo" class="flex items-center gap-2 relative pl-2">
              <div class="relative z-20 w-16 h-16 flex justify-center">
                 <div class="absolute -top-1 w-3 h-3 bg-gray-400 rounded-full shadow-sm z-30 border border-gray-500"></div>
                 <%= image_tag "logo.png", alt: "Sofuto Engine Logo", class: "absolute top-0 w-24 h-24 max-w-none object-contain drop-shadow-2xl logo-colgando z-10 hover:scale-110 transition-transform duration-300", onerror: "this.style.display='none'" %>
              </div>
              <span class="fuente-manuscrita-global text-5xl text-indigo-900 font-bold tracking-wide transform translate-y-3 rotate-[-6deg] drop-shadow-lg relative z-20 ml-6">
                Sofuto Engine
              </span>
            </div>

            <div id="header-minimalista" class="hidden flex items-center gap-4">
              <%= image_tag "logo.png", alt: "Sofuto Engine", class: "w-8 h-8 object-contain grayscale opacity-80", onerror: "this.style.display='none'" %>
              <span class="text-sm md:text-base font-light text-gray-800 tracking-[0.3em] uppercase mt-1">
                Sofuto Engine
              </span>
            </div>

            <div id="header-elegante" class="hidden flex items-center gap-3">
              <%= image_tag "logo.png", alt: "Sofuto Engine", class: "w-10 h-10 object-contain drop-shadow-md", onerror: "this.style.display='none'" %>
              <span class="text-xl font-serif tracking-widest uppercase text-amber-600 mt-1">
                Sofuto Engine
              </span>
            </div>

          </div>

          <div class="flex items-center gap-4">
            <a href="PON_AQUI_TU_LINK_DE_WHATSAPP" target="_blank" class="text-gray-400 hover:text-[#25D366] transition-colors transform hover:scale-110 duration-200">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href="PON_AQUI_TU_LINK_DE_INSTAGRAM" target="_blank" class="text-gray-400 hover:text-[#E1306C] transition-colors transform hover:scale-110 duration-200">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="PON_AQUI_TU_LINK_DE_FACEBOOK" target="_blank" class="text-gray-400 hover:text-[#1877F2] transition-colors transform hover:scale-110 duration-200">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>

        </div>
      </div>
    </header>

    <main class="w-full">
      <%= yield %>
    </main>

    <div class="fixed bottom-6 left-6 z-50">
      
      <div id="theme-menu-container" class="hidden absolute bottom-20 left-0 w-56 transition-all origin-bottom-left drop-shadow-2xl">
        
        <div id="menu-creativo" class="flex flex-col gap-0">
          <button onclick="activarDiseno('minimalista')" class="w-full text-center block px-4 py-4 bg-[#E2B97F] hover:bg-[#D4A360] text-[#5C3A21] font-bold rounded-t-[2.5rem] border-b-2 border-[#C69A56] transition-colors relative z-30">Minimalista</button>
          <button onclick="activarDiseno('creativo')" class="w-full text-center block px-4 py-4 bg-[#FFD700] hover:bg-[#F2A900] text-amber-900 font-bold transition-colors relative z-20 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.1)]">Creativo</button>
          <button onclick="activarDiseno('elegante')" class="w-full text-center block px-4 py-4 bg-[#E2B97F] hover:bg-[#D4A360] text-[#5C3A21] font-bold rounded-b-xl transition-colors relative z-10">Elegante</button>
        </div>

        <div id="menu-minimalista" class="hidden flex-col bg-white border border-gray-100 shadow-xl rounded-2xl overflow-hidden p-1.5 gap-1">
          <button onclick="activarDiseno('minimalista')" class="w-full text-left px-5 py-3 text-xs font-semibold tracking-[0.2em] uppercase text-gray-900 bg-gray-100 rounded-xl transition-colors">Minimalista.</button>
          <button onclick="activarDiseno('creativo')" class="w-full text-left px-5 py-3 text-xs font-light tracking-[0.2em] uppercase text-gray-500 hover:text-gray-900 hover:bg-gray-50 rounded-xl transition-colors">Creativo.</button>
          <button onclick="activarDiseno('elegante')" class="w-full text-left px-5 py-3 text-xs font-light tracking-[0.2em] uppercase text-gray-500 hover:text-gray-900 hover:bg-gray-50 rounded-xl transition-colors">Elegante.</button>
        </div>

        <div id="menu-elegante" class="hidden flex-col bg-slate-900 border border-slate-800 shadow-2xl rounded-sm p-2 gap-1">
          <button onclick="activarDiseno('minimalista')" class="w-full text-center px-4 py-3 text-xs font-serif tracking-widest uppercase text-slate-400 hover:text-amber-500 transition-colors">Minimalista</button>
          <button onclick="activarDiseno('creativo')" class="w-full text-center px-4 py-3 text-xs font-serif tracking-widest uppercase text-slate-400 hover:text-amber-500 transition-colors">Creativo</button>
          <button onclick="activarDiseno('elegante')" class="w-full text-center px-4 py-3 text-xs font-serif tracking-widest uppercase text-amber-500 border border-amber-500/30 bg-amber-500/10 transition-colors">Elegante</button>
        </div>

      </div>
      
      <button onclick="document.getElementById('theme-menu-container').classList.toggle('hidden')" class="w-16 h-16 bg-gray-900 rounded-full shadow-xl hover:bg-gray-800 focus:outline-none focus:ring-4 focus:ring-gray-300 transition-all active:scale-95 flex items-center justify-center text-3xl">
        <span id="icono-creativo">🍔</span>
        <span id="icono-minimalista" class="hidden"><svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path></svg></span>
        <span id="icono-elegante" class="hidden"><svg class="w-8 h-8 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg></span>
      </button>
      
    </div>

    <script>
      function activarDiseno(temaSeleccionado) {
        const temas = ['minimalista', 'creativo', 'elegante'];
        
        temas.forEach(tema => {
          // 1. Cambiar la vista principal
          const contenedor = document.getElementById(`diseno-${tema}`);
          if (contenedor) {
            if (tema === temaSeleccionado) {
              contenedor.classList.remove('hidden');
              setTimeout(() => {
                contenedor.classList.remove('opacity-0', 'translate-y-4');
                contenedor.classList.add('opacity-100', 'translate-y-0');
              }, 50);
            } else {
              contenedor.classList.remove('opacity-100', 'translate-y-0');
              contenedor.classList.add('opacity-0', 'translate-y-4');
              setTimeout(() => contenedor.classList.add('hidden'), 300);
            }
          }

          // 2. Cambiar la Cabecera (Logo y Nombre)
          const header = document.getElementById(`header-${tema}`);
          if (header) {
            if (tema === temaSeleccionado) {
              header.classList.remove('hidden');
            } else {
              header.classList.add('hidden');
            }
          }

          // 3. Cambiar el icono del Botón Flotante
          const icono = document.getElementById(`icono-${tema}`);
          if (icono) {
            if (tema === temaSeleccionado) {
              icono.classList.remove('hidden');
            } else {
              icono.classList.add('hidden');
            }
          }

          // 4. Cambiar el diseño del Menú Desplegable
          const menuTheme = document.getElementById(`menu-${tema}`);
          if (menuTheme) {
            if (tema === temaSeleccionado) {
              menuTheme.classList.remove('hidden');
              menuTheme.classList.add('flex');
            } else {
              menuTheme.classList.add('hidden');
              menuTheme.classList.remove('flex');
            }
          }
        });

        // Ocultar el contenedor general del menú al hacer clic
        document.getElementById('theme-menu-container').classList.add('hidden');
      }
    </script>
  </body>
</html>